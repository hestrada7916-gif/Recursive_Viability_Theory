    "symbol": "\\tau_{\\mathrm{rec}}",
    "definition": "Preserved recursively reopenable participatory continuity.",
    "interpretation": "Recursive temporality generated through stable reopenable accessibility-preserving recurrence.",
    "note": "Recursive temporality is the broader continuity class within which multiple temporal phase realizations may occur."
  },

  "recursive_temporal_phase_space": {
