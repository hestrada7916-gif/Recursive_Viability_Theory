    }
  },

  "local_transport_primitive": {
    "name": "Rotor cell",
    "symbol": "\\mathcal C_{\\mathrm{rotor}}",
    "definition": "Minimal local coordination structure capable of supporting recursively reopenable directional recurrence under constraint-compatible transport.",
    "principle": "Rotor dynamics form primitive local generators of recursive temporal continuity within the transport layer.",
    "canonical_relation": "\\mathcal C_{\\mathrm{rotor}} \\Rightarrow \\tau_{\\mathrm{local}}"
  },

  "phase_classes": [
    {
      "phase_id": "local_temporality",
      "symbol": "\\tau_{\\mathrm{local}}",
      "name": "Local Temporal Phase",
      "condition": "\\mathcal C_{\\mathrm{local}} > 0",
      "transport_behavior": "Local recurrent transport structure preserved.",
      "accessibility_behavior": "Local accessibility loops remain reopenable.",
      "interpretation": "Local recurrence generates local recursive time but does not guarantee scalable recursive temporal continuity."
    },
    {
      "phase_id": "integrated_temporality",
      "symbol": "\\tau_{\\mathrm{int}}",
      "name": "Integrated Temporal Phase",
      "condition": "\\mathcal C_{\\mathrm{local}} > 0 \\land \\mathcal C_{\\mathrm{global}} > 0",
      "transport_behavior": "Local recurrence stitched into scalable coherence.",
      "accessibility_behavior": "Globally reopenable accessibility preserved.",
      "interpretation": "Integrated recursive temporality is a global coherence phase rather than a simple sum of local recurrences.",
      "canonical_nonidentity": "\\tau_{\\mathrm{int}} \\neq \\sum_i \\tau_{\\mathrm{local},i}"
    },
    {
      "phase_id": "fragmented_temporality",
      "symbol": "\\tau_{\\mathrm{frag}}",
      "name": "Fragmented Temporal Phase",
      "condition": "\\mathcal C_{\\mathrm{local}} > 0 \\land \\mathcal C_{\\mathrm{global}} \\le 0",
      "transport_behavior": "Local recurrence persists while global integration fails.",
      "accessibility_behavior": "Local accessibility survives without scalable coherence.",
      "interpretation": "Fragmented temporality preserves local recursive continuity while losing globally reopenable recursive time."
    },
    {
      "phase_id": "trapped_temporality",
      "symbol": "\\tau_{\\mathrm{trap}}",
      "name": "Trapped Temporal Phase",
      "condition": "\\tau_{\\mathrm{rec}} > 0 \\land dV^+/dt < 0",
      "transport_behavior": "Recursive continuity persists while future accessibility contracts.",
      "accessibility_behavior": "Accessible futures progressively degenerate.",
      "interpretation": "Trapped temporality preserves continuity while degrading future viability."
    },
    {
      "phase_id": "locked_temporality",
      "symbol": "\\tau_{\\mathrm{lock}}",
      "name": "Locked Temporal Phase",
      "condition": "\\tau_{\\mathrm{rec}} > 0 \\land \\Sigma_{\\mathrm{obs}} \\uparrow \\land d_{\\mathrm{eff}} \\downarrow",
      "transport_behavior": "Continuity preserved through synchronized low-dimensional recurrence.",
      "accessibility_behavior": "Temporal option space compressed into constrained recurrent pathways.",
      "interpretation": "Locked temporality preserves continuity through compressed or forced recurrence.",
      "note": "Locked phases may temporarily stabilize continuity under severe constraint, but prolonged locking typically reduces adaptive future accessibility and rewovability."
    },
    {
      "phase_id": "collapsed_temporality",
      "symbol": "\\tau_{\\mathrm{coll}}",
      "name": "Collapsed Temporal Phase",
      "condition": "\\mathfrak A(\\mathcal D) < \\xi_c",
      "equivalent_condition": "\\tau_{\\mathrm{rec}} \\notin \\mathcal C_{\\mathrm{vpc}}",
      "transport_behavior": "Viability-preserving recursive transport fails.",
      "accessibility_behavior": "Admissible recursive future participation becomes nonviable.",
      "interpretation": "Collapse is loss of viability-preserving recursive temporal continuity.",
      "clarification": "Local recurrent structures may persist despite loss of globally admissible recursive temporality."
    },
    {
      "phase_id": "rewoven_temporality",
      "symbol": "\\tau_{\\mathrm{rew}}",
      "name": "Rewoven Temporal Phase",
      "condition": "\\mathcal W_{\\mathrm{rew}} : \\tau_* \\rightarrow \\tau_{\\mathrm{rec}}",
      "transport_behavior": "Regenerative dynamics reconstruct viable recursive continuity.",
      "accessibility_behavior": "Admissible future participation reopens after degenerative deformation.",
      "interpretation": "Recovery reweaves recursive temporal viability rather than merely restoring prior chronological state.",
      "source_phases": [
        "\\tau_{\\mathrm{frag}}",
        "\\tau_{\\mathrm{trap}}",
        "\\tau_{\\mathrm{lock}}",
        "\\tau_{\\mathrm{coll}}"
      ]
    }
  ],

  "phase_transition_structure": {
    "generative_transitions": [
      "\\tau_{\\mathrm{local}} \\rightarrow \\tau_{\\mathrm{int}} \\rightarrow \\tau_{\\mathrm{rec}}"
    ],
    "degenerative_transitions": [
      "\\tau_{\\mathrm{int}} \\rightarrow \\tau_{\\mathrm{frag}} \\rightarrow \\tau_{\\mathrm{trap}} \\rightarrow \\tau_{\\mathrm{lock}} \\rightarrow \\tau_{\\mathrm{coll}}"
    ],
    "regenerative_transitions": [
      "\\tau_{\\mathrm{frag}}, \\tau_{\\mathrm{trap}}, \\tau_{\\mathrm{lock}}, \\tau_{\\mathrm{coll}} \\xrightarrow{\\mathcal W_{\\mathrm{rew}}} \\tau_{\\mathrm{rew}} \\rightarrow \\tau_{\\mathrm{rec}}"
    ]
  },

  "metastability_principle": {
    "name": "Recursive temporal metastability",
    "statement": "Recursive temporal phases need not be sharply separated.",
    "extended_statement": "Systems may occupy metastable intermediate regimes exhibiting mixed local persistence, partial integration, constrained accessibility, and incomplete rewovability.",
