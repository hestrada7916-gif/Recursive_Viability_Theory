  "canonical_statement": "Recoverability is measured by how much recoverable structure survives passage through a phase corridor.",

  "deep_compression": "Recoverability is a property of passage.",

  "primitive_principle": {
    "statement": "A phase corridor is not characterized solely by its existence, width, or intensity. The critical property of a corridor is whether recoverable continuation survives traversal.",
    "interpretation": "A corridor is navigable only if recoverability survives passage."
  },

  "recoverability_transport_principle": {
    "statement": "Recoverability is transported through phase corridors.",
    "interpretation": "Recoverability is not merely possessed by a system. Recoverability propagates through transitional regions, and phase corridors function as transport media for recoverable continuation."
  },

  "recoverability_proxy": {
    "symbol": "R",
    "equation": "R = Phi_future * D_A * P_Phi",
    "variables": {
      "Phi_future": "future accessibility volume",
      "D_A": "accessibility differentiation",
      "P_Phi": "future-volume percolation"
    },
    "interpretation": "Recoverability increases with accessible future volume, future distinctiveness, and future-accessibility flow."
  },

  "corridor_recoverability_retention": {
    "symbol": "T_corridor",
    "equation": "T_corridor = R_exit / R_entry",
    "interpretation": "Corridor recoverability retention measures the fraction of recoverable organizational structure preserved across a transition region."
  },

  "corridor_transmission_interpretation": {
    "statement": "Corridor recoverability retention functions as a transmission coefficient.",
    "equation": "T_corridor = R_exit / R_entry",
    "interpretation": "The corridor acts as a medium, recoverability acts as the transported quantity, and retention measures transmission efficiency."
  },

  "traversability_retention_distinction": {
    "corridor_traversability": {
      "symbol": "Theta_corridor",
      "definition": "Whether a system can pass through a corridor."
    },
    "corridor_recoverability_retention": {
      "symbol": "T_corridor",
      "definition": "How much recoverability survives passage through a corridor."
    },
    "equation": "Theta_corridor != T_corridor",
    "interpretation": "A corridor may be traversable while still destroying recoverability."
  },

  "corridor_burden": {
    "symbol": "V_corridor",
    "equation": "V_corridor = integral_C Delta_P dp",
    "variables": {
      "Delta_P": "P_N - P_Phi"
    },
    "interpretation": "Corridor burden measures accumulated transition stress across a phase corridor."
  },

  "corridor_burden_law": {
    "equation": "V_corridor up => T_corridor down",
    "gradient_form": "dT_corridor / dV_corridor < 0",
    "interpretation": "Recoverability retention decreases as accumulated corridor burden increases."
  },

  "corridor_fragility_coefficient": {
    "symbol": "alpha_corridor",
    "candidate_relation": "T_corridor approximately exp(a - alpha_corridor * V_corridor)",
    "interpretation": "The corridor fragility coefficient measures the rate at which recoverability decays under accumulated corridor burden."
  },

  "corridor_state_vector": {
    "symbol": "C_vector",
    "equation": "C_vector = (W_corridor, I_corridor, V_corridor, T_corridor)",
    "components": {
      "W_corridor": "corridor width",
      "I_corridor": "peak corridor intensity",
      "V_corridor": "accumulated corridor burden",
      "T_corridor": "recoverability retention"
    },
    "interpretation": "Phase corridors possess measurable geometry and survivability structure."
  },

  "corridor_geometry": {
    "equation": "C_phase = (W_corridor, I_corridor, V_corridor, T_corridor)",
    "components": {
      "W_corridor": "corridor width",
      "I_corridor": "peak corridor intensity",
      "V_corridor": "accumulated corridor burden",
      "T_corridor": "recoverability retention"
    },
    "interpretation": "A complete corridor description requires extent, intensity, accumulated burden, and survivability."
  },

