    "description": "Canonical registry for VTFA observables, symbols, dependencies, phase definitions, empirical interfaces, and implementation governance."
  },
  "namespace_conventions": {
    "theoretical_objects": "no suffix",
    "estimated_objects": "_hat",
    "proxy_objects": "_tilde",
    "empirical_fits": "_emp",
    "averaged_objects": "_bar",
    "accumulated_objects": "calligraphic or explicit accumulated name",
